{
  "expo": {
    "name": "Vendeapp",
    "slug": "vendeapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./logo/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f7f9"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo/logo.png",
        "backgroundColor": "#f6f7f9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vendeapp.mobile"
    },
    "web": {
      "favicon": "./logo/logo.png"
    },
    "plugins": [
      "expo-font",
      "expo-audio"
    ]
  }
}
